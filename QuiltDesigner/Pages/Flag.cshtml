@page "/Flag"
@model QuiltDesigner.Pages.Flag

<partial name = "_TestPartial" model='(@Model.Swatchfilepath, @Model.Swatchfilenames, @Model.Shapes, @Model.Swatches)' />
    
@section scripts {
    <script type="text/javascript">
        var currpat;
        const swatchCollection = @Html.Raw(Json.Serialize(Model.Swatchfilenames));
        if (swatchCollection.length > 0)
        {
            currpat = swatchCollection[0];
        }
        //console.log(swatchCollection);
    </script>
    
    <script src="~/js/shared.js"></script>
    
